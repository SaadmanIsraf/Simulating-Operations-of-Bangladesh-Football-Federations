<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.summer26.section1.group10.simulatingoperationsofbangladeshfootballfederation.FoulsCardsController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Record Fouls and Cards"/>

    <Label text="Select Match:"/>
    <ComboBox fx:id="matchComboBox" prefWidth="300"/>

    <Label text="Select Player:"/>
    <ComboBox fx:id="playerComboBox" prefWidth="300"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Card/Foul Type:"/>
        <ComboBox fx:id="cardTypeComboBox" prefWidth="150"/>
        <Label text="Minute:"/>
        <TextField fx:id="minuteField" prefWidth="60"/>
    </HBox>

    <Button text="Save Record" onAction="#handleSaveRecord"/>
    <Label fx:id="messageLabel"/>

    <Label text="Records for selected match:"/>
    <ListView fx:id="recordsListView" prefHeight="140"/>

    <Button text="Back to Dashboard" onAction="#handleBack"/>
</VBox>
