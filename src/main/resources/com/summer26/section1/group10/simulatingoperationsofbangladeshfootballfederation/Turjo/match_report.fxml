<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.summer26.section1.group10.simulatingoperationsofbangladeshfootballfederation.MatchReportController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Submit Match Report"/>

    <Label text="Select Match:"/>
    <ComboBox fx:id="matchComboBox" prefWidth="300"/>

    <Label text="Report Details:"/>
    <TextArea fx:id="reportTextArea" prefHeight="180" wrapText="true"
              promptText="Describe the match: key events, conduct, incidents..."/>

    <Label fx:id="messageLabel"/>

    <Button text="Save Report" onAction="#handleSaveReport"/>
    <Button text="Back to Dashboard" onAction="#handleBack"/>
</VBox>
