<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.summer26.section1.group10.simulatingoperationsofbangladeshfootballfederation.UpdateResultController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Update Match Result"/>

    <Label text="Select Completed Match:"/>
    <ComboBox fx:id="matchComboBox" prefWidth="300"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Home Score:"/>
        <TextField fx:id="homeScoreField" prefWidth="60"/>
        <Label text="Away Score:"/>
        <TextField fx:id="awayScoreField" prefWidth="60"/>
    </HBox>

    <Button text="Publish Result" onAction="#handlePublishResult"/>
    <Label fx:id="messageLabel"/>

    <Button text="Back to Dashboard" onAction="#handleBack"/>
</VBox>
